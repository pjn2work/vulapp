meta {
  name: POST /api/v1/get-token
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/get-token
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "auth": {
      "username": "admin",
      "password": "easypassword"
    }
  }
}

script:post-response {
  var data = res.getBody();
  bru.setVar("bearerToken", data.reply.token);
}
